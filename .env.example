# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres
DB_HOST=HOST
DB_PORT=5432
DB_NAME=postgres
DB_USER=USER
DB_PASSWORD=PASSWORD

# Security
SECRET_KEY=change-me-generate-a-long-random-value
ENVIRONMENT=development
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# SMTP / transactional email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=PULSE CRM
SMTP_TLS=true
FRONTEND_BASE_URL=http://localhost:3000

# Brevo
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_WEBHOOK_SECRET=

# Gmail OAuth / API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/gmail/callback
GOOGLE_WEBHOOK_SECRET=
GMAIL_TOKEN_ENCRYPTION_KEY=change-me-generate-a-long-random-value
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.modify

# AI
ENABLE_AI=true
AI_PROVIDER=rule_based
MODEL_NAME=
OPENAI_API_KEY=
SCORING_PROVIDER=rule_based
AI_TIMEOUT=30

# Webhooks
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_TIMEOUT_SECONDS=10

# File storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=uploads
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document

